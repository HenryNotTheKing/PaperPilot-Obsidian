{
	"name": "obsidian-paperpilot",
	"version": "0.1.0",
	"description": "Paper Pilot — import arXiv papers, extract AI-powered highlights, and pilot your way through dense PDFs.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": ["obsidian", "obsidian-plugin", "arxiv", "ai", "llm", "pdf", "research", "papers"],
	"license": "MIT",
	"author": "HenryNotTheKing",
	"repository": {
		"type": "git",
		"url": "https://github.com/HenryNotTheKing/PaperPilot-Obsidian.git"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.39",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^29.0.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"obsidian": "latest",
		"pdfjs-dist": "^5.6.205"
	}
}
